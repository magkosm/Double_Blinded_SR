{
  "name": "double-blinded-sr",
  "private": true,
  "workspaces": [
    "app",
    "worker",
    "scripts"
  ],
  "scripts": {
    "dev": "npm run dev -w app",
    "dev:worker": "npm run dev -w worker",
    "build": "npm run build -w app",
    "test": "npm run test -w app && npm run test -w worker",
    "e2e": "npm run e2e -w app",
    "qa:full": "npm run test && npm run e2e && npm run build",
    "docs:screenshots": "npm run capture-docs -w scripts",
    "deploy:worker": "npm run deploy -w worker",
    "deploy:pages": "bash scripts/deploy-pages.sh",
    "bootstrap": "npm run bootstrap -w scripts",
    "upload-ris": "npm run upload-ris -w scripts",
    "migrate": "npm run migrate -w scripts",
    "upgrade-super-admin": "npm run upgrade-super-admin -w scripts",
    "sync-credentials": "npm run sync-credentials -w scripts"
  }
}
